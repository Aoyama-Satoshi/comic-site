<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta
            name="google-site-verification"
            content="roYRUTBqeKarxA6-eoJkTgeNWFqcaH0BWQQUFw4Yg9M"
        />
        <title>英語四コマ漫画サイト----</title>
    </head>
    <body class="index-background-image">
        <header>
            <h1>英語四コマ漫画サイト</h1>
            <p>このサイトは、四コマ漫画で英語を学習することができます。</p>
        </header>
        <main>
            <a href="/manga-list" class="button">英語四コマ一覧</a>
            <a href="/AI" class="button">AI英文生成学習</a>
            <a href="/about" class="button">このサイトについて</a>
            <div class="container">
                <ul class="manga-grid">
                    <li class="manga-card">
                        <a href="/manga/manga001">
                            <div class="thumb-wrapper">
                                <img
                                    src="/images/manga001.png"
                                    alt="Singlish"
                                    class="thumb"
                                />
                            </div>
                            <div class="card-info">
                                <span class="tag beginner">Beginner</span>
                            </div>
                        </a>
                    </li>

                    <li class="manga-card">
                        <a href="/manga/manga002">
                            <div class="thumb-wrapper">
                                <img
                                    src="/images/manga002.png"
                                    alt="Luck"
                                    class="thumb"
                                />
                            </div>
                            <div class="card-info">
                                <span class="tag intermediate"
                                    >Intermediate</span
                                >
                            </div>
                        </a>
                    </li>
                </ul>
            </div>
        </main>
        <footer>
            <small>© English Manga Site</small>
        </footer>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        padding: 0;
    }

    header {
        background-image: url("/images/mokume.jpeg");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        margin: 0;
        padding: 20px;
    }

    main {
        margin: 0;
        padding: 20px;
        min-height: 100dvh;
        background-image: url("/images/index-background-image.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    /* グリッド全体の設定 */
    .manga-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 24px;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    /* カード1枚の設定：ここが透明化の対策です */
    .manga-card {
        width: 300px;
        background-color: #ffffff; /* 重なり防止：背景を真っ白にして後ろのイラストを隠す */
        border: 2px solid #333333; /* 線を少しハッキリ太く */
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05); /* ほんのり影をつけて立体感 */
    }

    /* リンク全体の文字装飾を消す */
    .manga-card a {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    /* 画像を囲む枠：ここで高さを固定してはみ出た部分を非表示にする */
    .thumb-wrapper {
        width: 100%;
        height: 310px; /* タイトルと1コマ目がちょうど収まるくらい。表示を見ながら数値を調整してください */
        overflow: hidden;
    }

    /* 画像の切り取り設定 */
    .manga-card .thumb {
        width: 100%;
        height: 100%;
        object-fit: cover; /* 横幅いっぱいに引き伸ばしてトリミング */
        object-position: top; /* 画像の「一番上（タイトル＋1コマ目）」を強制表示 */
    }

    /* タグを入れる下の余白エリア */
    .card-info {
        padding: 12px;
        background-color: #ffffff;
        border-top: 1px solid #eee;
    }

    /* タグの見た目 */
    .tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: bold;
    }
    .tag.beginner {
        background-color: #ffe0b2;
        color: #b71c1c;
    }
    .tag.intermediate {
        background-color: #e1f5fe;
        color: #0288d1;
    }

    footer {
        background: #707070;
        margin: 0;
        padding: 12px 20px;
    }

    h1,
    p {
        margin-top: 0;
    }

    .button {
        display: inline-block;
        padding: 10px 18px;

        border: 2px solid black;
        border-radius: 999px;

        text-decoration: none;
        color: black;

        font-weight: bold;
    }

    /* ── 基本のデザイン（スマホ・縦一列） ── */
    .menu-list {
        display: flex;
        flex-direction: column; /* 縦に並べる */
        gap: 20px;
    }

    /* ── 画面の横幅が 768px 以上（タブレット・PC）になったら ── */
    @media (min-width: 768px) {
        .menu-list {
            flex-direction: row; /* 横に並べる！ */
            flex-wrap: wrap; /* 入りきらない分は折り返す */
        }
    }
</style>

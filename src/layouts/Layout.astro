---
import '../styles/global.css';

interface Props {
	title?: string;
	lang?: string;
	pageClass?: string;
}

const { title = 'Astro Basics', lang = 'en', pageClass = '' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class={pageClass}>
		<header>
			<a href="/">英語四コマ漫画サイト</a>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<small>© English Manga Site</small>
		</footer>
	</body>
</html>
